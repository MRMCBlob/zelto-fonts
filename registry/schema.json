{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "examples": [
        "sans",
        "serif",
        "mono",
        "display"
      ]
    },
    "designer": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "type",
        "url"
      ]
    },
    "source": {
      "type": "string",
      "format": "uri"
    },
    "variable": {
      "type": "boolean"
    },
    "axes": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "array",
        "prefixItems": [
          {
            "type": "number"
          },
          {
            "type": "number"
          }
        ]
      }
    },
    "weights": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1000
      }
    },
    "styles": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "normal",
          "italic"
        ]
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ligatures",
          "extended-charset",
          "nerd-font",
          "rtl"
        ]
      }
    },
    "fallback": {
      "type": "string",
      "minLength": 1
    },
    "previewText": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "submittedBy": {
      "type": "object",
      "properties": {
        "github": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-]+$"
        }
      },
      "required": [
        "github"
      ]
    },
    "files": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^\\/r\\/fonts\\/[a-z0-9-]+\\/[^/]+\\.woff2$"
          },
          "weight": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 1,
                "maximum": 1000
              },
              {
                "type": "string",
                "pattern": "^\\d+ \\d+$"
              }
            ]
          },
          "style": {
            "type": "string",
            "enum": [
              "normal",
              "italic"
            ]
          }
        },
        "required": [
          "path",
          "weight",
          "style"
        ]
      }
    }
  },
  "required": [
    "name",
    "displayName",
    "version",
    "category",
    "designer",
    "license",
    "source",
    "variable",
    "weights",
    "styles",
    "fallback",
    "previewText",
    "description",
    "submittedBy",
    "files"
  ]
}